{
  "require": {
    "php": "^8.3",
    "symfony/yaml": "^6",
    "guzzlehttp/guzzle": "^7"
  },
  "autoload": {
    "psr-4": {
      "AwesomeList\\": "lib/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "AwesomeList\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^12",
    "justinrainbow/json-schema": "^5"
  },
  "scripts": {
    "validate-data": "php bin/validate-data.php",
    "test":          "phpunit",
    "enrich":        "php bin/enrich.php",
    "discover":      "php bin/discover.php",
    "accept-candidate": "php bin/accept-candidate.php",
    "prune-dead":       "php bin/prune-dead.php"
  }
}
